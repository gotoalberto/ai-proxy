# AWS Credentials for Secrets Manager Access
# These credentials need permissions to read/write secrets in AWS Secrets Manager
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1

# Secrets Manager Configuration
SECRETS_PREFIX=ai-proxy/

# Optional: Cache TTL for secrets (in seconds, default: 300 = 5 minutes)
SECRETS_CACHE_TTL=300

# Optional: Environment (development, staging, production)
NODE_ENV=development
